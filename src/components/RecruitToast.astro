---
// 招募公告 · 非阻断式左下角玻璃卡
// 内容运行时从 /api/recruits 读取（管理员可在后台自助编辑/多条投放）；
// 组件内写死一条 fallback（CF 不可用时仍展示），deadline 过期则整体不显示。
// 设计原则：不挡 Hero、不引起布局抖动（fixed 浮层）、可关闭、localStorage 按 id 记忆不再弹
const FALLBACK = {
  id: 'default',
  title: '研修生招募',
  subtitle: '公主风王道系地下偶像团体',
  body: '微博转发关注抽 52 元偶活基金',
  cta_text: '查看详情 →',
  cta_url: 'https://weibo.com/7972735157/R7KNSzPdt',
  deadline: '2026-08-10',
};
---

<div
  id="recruit-toast"
  class="recruit-toast"
  role="status"
  aria-live="polite"
  data-id={FALLBACK.id}
  data-deadline={FALLBACK.deadline}
  data-subtitle={FALLBACK.subtitle}
  data-body={FALLBACK.body}
>
  <button type="button" class="recruit-close" aria-label="关闭招募通知">&times;</button>
  <p class="recruit-title" data-field="title">{FALLBACK.title}</p>
  <p class="recruit-sub" data-field="subtitle">{FALLBACK.subtitle}</p>
  <p class="recruit-meta" data-field="meta"></p>
  <a class="recruit-cta" data-field="cta" href={FALLBACK.cta_url} target="_blank" rel="noopener">{FALLBACK.cta_text}</a>
</div>

<style>
  .recruit-toast {
    position: fixed;
    left: 1.25rem;
    bottom: calc(1.25rem + env(safe-area-inset-bottom));
    z-index: 40;
    width: 320px;
    max-width: calc(100vw - 2.5rem);
    padding: 1rem 1.1rem 1.1rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-left: 3px solid var(--accent);
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.52));
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    box-shadow: var(--shadow-md), inset 0 1px 0 rgba(255, 255, 255, 0.5);
    color: var(--text);
    opacity: 0;
    transform: translateY(16px);
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.5s var(--ease), transform 0.5s var(--ease), visibility 0.5s var(--ease);
  }
  .recruit-toast.show {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
    pointer-events: auto;
  }
  .dark .recruit-toast {
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.035));
    border-color: rgba(255, 255, 255, 0.09);
    border-left-color: var(--accent);
    box-shadow: var(--shadow-md), inset 0 1px 0 rgba(255, 255, 255, 0.07);
    color: #c8c3da;
  }

  .recruit-title {
    font-size: 0.9375rem; font-weight: 700; color: var(--accent);
    margin-bottom: 0.15rem; line-height: 1.3;
  }
  .dark .recruit-title { color: var(--accent); }
  .recruit-sub {
    font-size: 0.75rem; color: var(--text-soft); line-height: 1.4;
    margin-bottom: 0.45rem;
  }
  .recruit-meta {
    font-size: 0.75rem; color: var(--text-soft); line-height: 1.45; margin-bottom: 0.7rem;
  }
  .recruit-accent { color: var(--accent); font-weight: 700; }
  .dark .recruit-meta { color: #a59fc0; }
  .recruit-cta {
    display: inline-flex; align-items: center; gap: 0.25rem;
    font-size: 0.8125rem; font-weight: 700; color: var(--accent);
    text-decoration: none;
    transition: gap 0.2s var(--ease);
  }
  .recruit-cta:hover { gap: 0.5rem; }
  .recruit-close {
    position: absolute; top: 0.5rem; right: 0.5rem;
    width: 1.5rem; height: 1.5rem; border-radius: 9999px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; line-height: 1; color: var(--text-soft);
    background: transparent; border: none; cursor: pointer;
    transition: background 0.2s var(--ease), color 0.2s var(--ease);
  }
  .recruit-close:hover { background: rgba(20, 14, 40, 0.06); color: var(--text); }
  .dark .recruit-close:hover { background: rgba(255, 255, 255, 0.08); color: #ece9f4; }

  /* 移动端：留出右下角返回顶部按钮的空间 */
  @media (max-width: 767px) {
    .recruit-toast {
      left: 1rem;
      right: 4.5rem;
      width: auto;
      max-width: none;
    }
  }

  /* 无障碍：减少动态效果时只淡入、不位移 */
  @media (prefers-reduced-motion: reduce) {
    .recruit-toast { transition: opacity 0.25s ease; transform: none; }
    .recruit-toast.show { transform: none; }
  }
</style>

<script is:inline>
  (function () {
    var el = document.getElementById('recruit-toast');
    if (!el) return;

    // 按 id 记忆已关闭的招募，互不干扰
    var KEY_CLOSED = 'gleams-recruit-closed';
    function getClosed() {
      try { return JSON.parse(localStorage.getItem(KEY_CLOSED) || '[]'); } catch (e) { return []; }
    }
    function addClosed(id) {
      try {
        var a = getClosed();
        if (a.indexOf(id) === -1) a.push(id);
        localStorage.setItem(KEY_CLOSED, JSON.stringify(a));
      } catch (e) {}
    }

    // 当前生效条目（先取组件内写死的 fallback）
    var current = {
      id: el.dataset.id || 'default',
      title: el.querySelector('[data-field="title"]').textContent,
      subtitle: el.dataset.subtitle || '',
      body: el.dataset.body || '',
      cta_text: el.querySelector('[data-field="cta"]').textContent,
      cta_url: el.querySelector('[data-field="cta"]').getAttribute('href'),
      deadline: el.dataset.deadline || null,
    };

    // 先用 fallback 渲染（含强调色 meta 行），fetch 成功后再覆盖
    renderMeta();

    // 按本地时间判定：deadline 为 'YYYY-MM-DD'，视为该日北京时间 23:59:59 前有效
    function isActive(deadline) {
      if (!deadline) return true;
      var end = new Date(deadline + 'T23:59:59+08:00');
      return Date.now() <= end.getTime();
    }

    // 截止日格式化为「M.DD」（如 2026-08-10 → 8.10）
    function fmtDeadline(d) {
      if (!d) return '';
      var m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(d);
      if (!m) return d;
      return parseInt(m[2], 10) + '.' + m[3];
    }

    // 以安全方式重建 meta 行：强调色片段 + 普通正文（避免 innerHTML 注入）
    function renderMeta() {
      var metaEl = el.querySelector('[data-field="meta"]');
      metaEl.textContent = '';
      if (current.deadline) {
        var acc = document.createElement('span');
        acc.className = 'recruit-accent';
        acc.textContent = '报名截止 ' + fmtDeadline(current.deadline);
        metaEl.appendChild(acc);
        metaEl.appendChild(document.createTextNode(' · ' + (current.body || '')));
      } else {
        metaEl.textContent = current.body || '';
      }
    }

    function applyRecruit(r) {
      el.dataset.id = String(r.id);
      el.dataset.deadline = r.deadline || '';
      el.dataset.subtitle = r.subtitle || '';
      el.dataset.body = r.body || '';
      el.querySelector('[data-field="title"]').textContent = r.title;
      var sub = el.querySelector('[data-field="subtitle"]');
      sub.textContent = r.subtitle || '';
      sub.style.display = r.subtitle ? '' : 'none';
      renderMeta();
      var cta = el.querySelector('[data-field="cta"]');
      cta.textContent = r.cta_text || '查看详情 →';
      cta.setAttribute('href', r.cta_url || '#');
    }

    var shown = false;
    function showCurrent() {
      if (shown) return;
      if (getClosed().indexOf(String(current.id)) !== -1) return;  // 关过不再弹
      if (!isActive(current.deadline)) { el.remove(); return; }     // 过期则整体不显示
      shown = true;
      requestAnimationFrame(function () {
        requestAnimationFrame(function () { el.classList.add('show'); });
      });
    }

    function close() {
      el.classList.remove('show');
      addClosed(String(current.id));
    }
    var closeBtn = el.querySelector('.recruit-close');
    if (closeBtn) closeBtn.addEventListener('click', close);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && el.classList.contains('show')) close();
    });

    // 拉取后端有效条目（sort_order 升序首条），成功则覆盖 fallback
    fetch('/api/recruits')
      .then(function (r) { return r.json(); })
      .then(function (list) {
        if (Array.isArray(list) && list.length) {
          var r = list[0];
          current = {
            id: r.id, title: r.title, subtitle: r.subtitle || '',
            body: r.body,
            cta_text: r.cta_text, cta_url: r.cta_url,
            deadline: r.deadline || null,
          };
          applyRecruit(current);
        }
        showCurrent();
      })
      .catch(function () { showCurrent(); });

    // 兜底：fetch 缓慢时 2s 后按 fallback 显示，不阻塞
    setTimeout(function () { if (!shown) showCurrent(); }, 2000);
  })();
</script>
