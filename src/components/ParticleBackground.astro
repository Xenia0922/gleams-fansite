<div
  class="absolute inset-0 overflow-hidden pointer-events-none"
  aria-hidden="true"
>
  <!-- Stars -->
  <div class="absolute inset-0" id="stars-container"></div>

  <!-- Gradient orbs -->
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-gleams-500/10 rounded-full blur-3xl animate-float"></div>
  <div class="absolute top-1/3 -right-32 w-80 h-80 bg-dream-400/10 rounded-full blur-3xl animate-float-delayed"></div>
  <div class="absolute bottom-1/4 left-1/3 w-64 h-64 bg-dream-500/8 rounded-full blur-3xl animate-float"></div>
</div>

<script>
  function createStars() {
    const container = document.getElementById('stars-container');
    if (!container) return;
    const count = 80;

    for (let i = 0; i < count; i++) {
      const star = document.createElement('div');
      const size = Math.random() * 3 + 1;
      const x = Math.random() * 100;
      const y = Math.random() * 100;
      const duration = Math.random() * 4 + 2;
      const delay = Math.random() * 5;

      star.className = 'star';
      star.style.cssText = `
        width: ${size}px;
        height: ${size}px;
        left: ${x}%;
        top: ${y}%;
        --duration: ${duration}s;
        animation-delay: ${delay}s;
      `;
      container.appendChild(star);
    }
  }

  createStars();
</script>
