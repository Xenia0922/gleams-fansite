---
import ParticleBackground from './ParticleBackground.astro';
import site from '../data/site.json';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <ParticleBackground />

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <!-- Badge -->
    <div class="animate-fade-in mb-8">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full
                   bg-white/[0.03] border border-white/[0.08] backdrop-blur-sm
                   text-white/60 text-xs tracking-widest">
        <span class="w-2 h-2 rounded-full bg-gleams-500 animate-pulse"></span>
        {site.nameJP}
      </span>
    </div>

    <!-- Main Title -->
    <h1 class="animate-slide-up mb-6">
      <span class="block text-5xl sm:text-7xl md:text-8xl lg:text-9xl font-display font-extrabold
                   tracking-tight leading-none">
        <span class="gradient-text">{site.name}</span>
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="animate-slide-up-delayed text-lg md:text-xl text-white/40 max-w-2xl mx-auto mb-10 leading-relaxed">
      {site.descriptionCN}
    </p>

    <!-- CTA Buttons -->
    <div class="animate-slide-up-delayed flex flex-wrap items-center justify-center gap-4">
      <a href="/members" class="btn-primary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
        认识成员
      </a>
      <a href="/schedule" class="btn-outline">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        公演日程
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce-gentle">
      <svg class="w-6 h-6 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </div>
</section>
