---
import site from '../data/site.json';

const currentPath = Astro.url?.pathname || '';

const navLinks = [
  { href: '/', label: '首页' },
  { href: '/members', label: '成员' },
  { href: '/schedule', label: '日程' },
  { href: '/gallery', label: '画廊' },
  { href: '/fans', label: '广场' },
  { href: '/tokuten', label: '特典' },
  { href: '/about', label: '关于' },
];
---

<header class="fixed top-0 left-0 right-0 z-50">
  <div class="frost">
    <div class="max-w-7xl mx-auto px-3 sm:px-4">
      <div class="flex items-center justify-between h-12 sm:h-14 md:h-16 relative">
        <a href="/" class="flex items-center gap-2 sm:gap-2.5 flex-shrink-0">
          <img src="/logo.png" alt={site.name} class="w-7 h-7 sm:w-8 sm:h-8 rounded-full" />
          <span class="text-base sm:text-lg md:text-xl font-extrabold tracking-tight text-pink-500">{site.name}</span>
          <span class="hidden sm:inline text-[8px] sm:text-[10px] text-gray-400 tracking-widest">Fansite</span>
        </a>

        <!-- Desktop Nav — centered with absolute -->
        <nav class="hidden md:flex items-center gap-0 absolute left-1/2 -translate-x-1/2">
          {navLinks.map(link => {
            const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
            return (
              <a
                href={link.href}
                class={`relative px-3 py-5 text-xs tracking-widest transition-all duration-200 border-b-2 ${
                  isActive
                    ? 'text-pink-500 border-pink-500 font-bold dark:text-pink-400'
                    : 'text-gray-500 dark:text-gray-400 border-transparent hover:text-pink-500 hover:border-pink-300'
                }`}
              >
                {link.label}
              </a>
            );
          })}
        </nav>

        <!-- SNS Icons + Dark Mode -->
        <div class="hidden md:flex items-center gap-3">
          <a href={site.weibo} target="_blank" rel="noopener" class="opacity-40 hover:opacity-100 transition-opacity" title="微博">
            <img src="/icon-weibo.png" alt="微博" class="w-4 h-4" />
          </a>
          <a href={site.xiaohongshu} target="_blank" rel="noopener" class="opacity-40 hover:opacity-100 transition-opacity" title="小红书">
            <img src="/icon-xhs.png" alt="小红书" class="w-4 h-4" />
          </a>
          <a href={site.douyin} target="_blank" rel="noopener" class="opacity-40 hover:opacity-100 transition-opacity" title="抖音">
            <img src="/icon-douyin.png" alt="抖音" class="w-4 h-4" />
          </a>
          <span class="text-gray-300 dark:text-gray-700 dark:text-gray-300">|</span>
          <button id="dark-toggle" class="p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" aria-label="暗黑模式" title="暗黑模式">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path class="sun" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
              <path class="moon hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
            </svg>
          </button>
        </div>

        <!-- Mobile: dark toggle + hamburger -->
        <div class="flex md:hidden items-center gap-1">
          <button id="dark-toggle-m" class="p-2 text-gray-400" aria-label="暗黑模式">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path class="sun" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
              <path class="moon hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
            </svg>
          </button>
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-500" aria-label="菜单">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path class="menu-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            <path class="menu-close hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M6 18L18 6"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden frost border-b border-pink-100/40 dark:border-white/[0.04] shadow-lg overflow-hidden transition-all duration-300 max-h-0 rounded-b-3xl">
    <div class="px-4 py-2 space-y-0">
      {navLinks.map(link => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <a href={link.href} class={`block py-3 px-3 text-sm tracking-widest border-l-2 transition-colors ${isActive ? 'text-pink-500 border-pink-500 font-bold dark:text-pink-400 bg-pink-50 dark:bg-gray-800' : 'text-gray-600 border-transparent hover:text-pink-400 hover:bg-pink-50'}`}>
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</header>

<!-- Spacer -->
<div class="h-12 sm:h-14 md:h-16"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.querySelector('.menu-open') as HTMLElement;
  const closeIcon = document.querySelector('.menu-close') as HTMLElement;

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('max-h-96');
    if (isOpen) {
      menu?.classList.remove('max-h-96');
      menu?.classList.add('max-h-0');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    } else {
      menu?.classList.remove('max-h-0');
      menu?.classList.add('max-h-96');
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    }
  });
</script>

<script>
  function setupDarkToggle(btnId) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    const sun = btn.querySelector('.sun');
    const moon = btn.querySelector('.moon');
    const isDark = localStorage.getItem('dark') === '1';
    if (isDark) { document.documentElement.classList.add('dark'); sun?.classList.add('hidden'); moon?.classList.remove('hidden'); }
    btn.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      const d = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.sun').forEach(s => s.classList.toggle('hidden', d));
      document.querySelectorAll('.moon').forEach(s => s.classList.toggle('hidden', !d));
      localStorage.setItem('dark', d ? '1' : '0');
    });
  }
  setupDarkToggle('dark-toggle');
  setupDarkToggle('dark-toggle-m');
</script>
