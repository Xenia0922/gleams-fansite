---
import site from '../data/site.json';

const currentPath = Astro.url?.pathname || '';

const navLinks = [
  { href: '/', label: '首页' },
  { href: '/news', label: '活动' },
  { href: '/members', label: '成员' },
  { href: '/schedule', label: '日程' },
  { href: '/gallery', label: '画廊' },
  { href: '/tokuten', label: '特典' },
  { href: '/about', label: '关于' },
];
---

<header class="fixed top-0 left-0 right-0 z-50">
  <div class="bg-white/95 backdrop-blur-md border-b border-pink-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-3 sm:px-4">
      <div class="flex items-center justify-between h-12 sm:h-14 md:h-16">
        <a href="/" class="flex items-center gap-1.5 sm:gap-2 flex-shrink-0">
          <span class="text-base sm:text-lg md:text-xl font-extrabold tracking-tight text-pink-500">{site.name}</span>
          <span class="hidden sm:inline text-[8px] sm:text-[10px] text-gray-400 tracking-widest">应援站</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-0">
          {navLinks.map(link => {
            const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
            return (
              <a
                href={link.href}
                class={`relative px-3 py-5 text-xs tracking-widest transition-all duration-200 border-b-2 ${
                  isActive
                    ? 'text-pink-500 border-pink-500 font-bold'
                    : 'text-gray-500 border-transparent hover:text-pink-500 hover:border-pink-300'
                }`}
              >
                {link.label}
              </a>
            );
          })}
        </nav>

        <!-- SNS Icons -->
        <div class="hidden md:flex items-center gap-3">
          <a href={site.weibo} target="_blank" rel="noopener" class="flex items-center justify-center w-4 h-4 rounded-sm bg-[#E6162D] text-white text-[8px] font-extrabold hover:opacity-80 transition-opacity" title="微博">微</a>
          </a>
          <a href={site.xiaohongshu} target="_blank" rel="noopener" class="text-gray-400 hover:text-red-400 transition-colors" title="小红书">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="4" fill="none" stroke="currentColor" stroke-width="2"/><text x="12" y="17" text-anchor="middle" font-size="11" font-weight="bold" fill="currentColor">红</text></svg>
          </a>
          <a href={site.douyin} target="_blank" rel="noopener" class="text-gray-400 hover:text-gray-700 transition-colors" title="抖音">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-500" aria-label="菜单">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path class="menu-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            <path class="menu-close hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M6 18L18 6"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden bg-white border-b border-pink-100 shadow-lg overflow-hidden transition-all duration-300 max-h-0">
    <div class="px-4 py-2 space-y-0">
      {navLinks.map(link => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <a href={link.href} class={`block py-3 px-3 text-sm tracking-widest border-l-2 transition-colors ${isActive ? 'text-pink-500 border-pink-500 font-bold bg-pink-50' : 'text-gray-600 border-transparent hover:text-pink-400 hover:bg-pink-50'}`}>
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</header>

<!-- Spacer -->
<div class="h-12 sm:h-14 md:h-16"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.querySelector('.menu-open') as HTMLElement;
  const closeIcon = document.querySelector('.menu-close') as HTMLElement;

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('max-h-96');
    if (isOpen) {
      menu?.classList.remove('max-h-96');
      menu?.classList.add('max-h-0');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    } else {
      menu?.classList.remove('max-h-0');
      menu?.classList.add('max-h-96');
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    }
  });
</script>
