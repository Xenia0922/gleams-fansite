---
import site from '../data/site.json';
---

<footer class="relative mt-32 pb-12">
  <!-- Gradient line -->
  <div class="h-px bg-gradient-to-r from-transparent via-gleams-500/30 to-transparent mb-12"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <span class="text-2xl">💎</span>
          <span class="text-xl font-display font-bold gradient-text">{site.name}</span>
        </div>
        <p class="text-sm text-white/40 leading-relaxed">
          {site.descriptionCN}
        </p>
        <div class="flex items-center gap-3 pt-2">
          <a href={site.social.weibo} class="text-white/30 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener" title="微博">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M10.098 20.323c-3.977.391-7.414-1.406-7.672-4.02-.259-2.609 2.759-5.047 6.74-5.441 3.979-.394 7.413 1.404 7.671 4.018.259 2.6-2.759 5.049-6.739 5.443z"/></svg>
          </a>
          <a href={site.social.bilibili} class="text-white/30 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener" title="哔哩哔哩">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 01-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 01.16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c0-.373.129-.689.386-.947.258-.257.574-.386.947-.386zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373z"/>
            </svg>
          </a>
          <a href={site.social.douyin} class="text-white/30 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener" title="抖音">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="grid grid-cols-2 gap-6">
        <div class="space-y-3">
          <h4 class="text-sm font-medium text-white/60 tracking-wider uppercase">导航</h4>
          <div class="space-y-2">
            {['首页', '成员介绍', '公演日程', '新闻动态'].map((label, i) => {
              const hrefs = ['/', '/members', '/schedule', '/news'];
              return (
                <a href={hrefs[i]} class="block text-sm text-white/40 hover:text-gleams-400 transition-colors">{label}</a>
              );
            })}
          </div>
        </div>
        <div class="space-y-3">
          <h4 class="text-sm font-medium text-white/60 tracking-wider uppercase">社交</h4>
          <div class="space-y-2">
            <a href={site.social.weibo} class="block text-sm text-white/40 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener">微博</a>
            <a href={site.social.bilibili} class="block text-sm text-white/40 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener">哔哩哔哩</a>
            <a href={site.social.douyin} class="block text-sm text-white/40 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener">抖音</a>
            <a href="/about" class="block text-sm text-white/40 hover:text-gleams-400 transition-colors">关于我们</a>
          </div>
        </div>
      </div>

      <!-- Community -->
      <div class="space-y-4">
        <h4 class="text-sm font-medium text-white/60 tracking-wider uppercase">加入骑士团</h4>
        <p class="text-sm text-white/40 leading-relaxed">
          QQ 群：{site.qqGroup}「{site.qqGroupName}」
        </p>
        <p class="text-sm text-white/40 leading-relaxed">
          关注微博获取 Gleams 最新演出情报！
        </p>
        <a href={site.social.weibo} class="btn-outline text-xs !px-4 !py-2 inline-flex" target="_blank" rel="noopener">
          关注微博
        </a>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-6 border-t border-white/[0.04] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/20">
        &copy; 2026 {site.name}. Made with 💖 by 西乡塘公主骑士团.
      </p>
      <p class="text-xs text-white/20">
        gleams.vip · {site.location}
      </p>
    </div>
  </div>
</footer>
