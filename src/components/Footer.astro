---
import site from '../data/site.json';
---

<footer class="bg-gray-900 text-white">
  <!-- 渐变过渡 -->
  <div class="h-16 bg-gradient-to-b from-white to-gray-900"></div>
  
  <div class="max-w-7xl mx-auto px-4 pb-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div>
        <h4 class="text-xs tracking-widest text-gray-500 uppercase mb-4">导航</h4>
        <div class="space-y-2.5">
          <a href="/" class="block text-sm text-gray-400 hover:text-white transition-colors">首页</a>
          <a href="/members" class="block text-sm text-gray-400 hover:text-white transition-colors">成员</a>
          <a href="/schedule" class="block text-sm text-gray-400 hover:text-white transition-colors">日程</a>
          <a href="/news" class="block text-sm text-gray-400 hover:text-white transition-colors">活动</a>
          <a href="/gallery" class="block text-sm text-gray-400 hover:text-white transition-colors">画廊</a>
        </div>
      </div>

      <div>
        <h4 class="text-xs tracking-widest text-gray-500 uppercase mb-4">应援</h4>
        <div class="space-y-2.5">
          <a href="/tokuten" class="block text-sm text-gray-400 hover:text-white transition-colors">特典规则</a>
          <a href="/about" class="block text-sm text-gray-400 hover:text-white transition-colors">关于我们</a>
        </div>
        <div class="mt-4 pt-4 border-t border-gray-800">
          <p class="text-xs text-gray-500 mb-1">QQ群：{site.qqGroup}</p>
          <p class="text-xs text-gray-500">{site.qqGroupName}</p>
        </div>
      </div>

      <div>
        <h4 class="text-xs tracking-widest text-gray-500 uppercase mb-4">关注</h4>
        <div class="space-y-2.5">
          <a href={site.weibo} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
            <img src="/icon-weibo.png" alt="" class="w-4 h-4" /> 微博
          </a>
          <a href={site.xiaohongshu} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
            <img src="/icon-xhs.png" alt="" class="w-4 h-4" /> 小红书
          </a>
          <a href={site.douyin} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg> 抖音
          </a>
        </div>
      </div>

      <div>
        <h4 class="text-xs tracking-widest text-gray-500 uppercase mb-4">{site.name}</h4>
        <p class="text-sm text-gray-500 leading-relaxed">{site.subtitle}</p>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-gray-800 text-center text-xs text-gray-600">
      &copy; 2026 {site.name} 应援站 · gleams.vip
    </div>
  </div>
</footer>
