---
import site from '../data/site.json';
---

<footer class="bg-gray-900 text-white py-12 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <h3 class="text-lg font-bold text-pink-400 mb-3">{site.name}</h3>
        <p class="text-gray-400 text-sm leading-relaxed mb-4">{site.subtitle}</p>
        <p class="text-gray-500 text-xs">QQ群：{site.qqGroup}<br/>{site.qqGroupName}</p>
      </div>

      <!-- Nav -->
      <div>
        <h4 class="text-xs tracking-widest text-gray-500 uppercase mb-3">导航</h4>
        <div class="space-y-2">
          <a href="/" class="block text-sm text-gray-400 hover:text-pink-400">首页</a>
          <a href="/news" class="block text-sm text-gray-400 hover:text-pink-400">活动</a>
          <a href="/members" class="block text-sm text-gray-400 hover:text-pink-400">成员</a>
          <a href="/schedule" class="block text-sm text-gray-400 hover:text-pink-400">日程</a>
        </div>
      </div>

      <div>
        <h4 class="text-xs tracking-widest text-gray-500 uppercase mb-3">更多</h4>
        <div class="space-y-2">
          <a href="/gallery" class="block text-sm text-gray-400 hover:text-pink-400">画廊</a>
          <a href="/tokuten" class="block text-sm text-gray-400 hover:text-pink-400">特典规则</a>
          <a href="/about" class="block text-sm text-gray-400 hover:text-pink-400">关于</a>
        </div>
      </div>

      <!-- SNS -->
      <div>
        <h4 class="text-xs tracking-widest text-gray-500 uppercase mb-3">关注</h4>
        <div class="space-y-2">
          <a href={site.weibo} target="_blank" rel="noopener" class="block text-sm text-gray-400 hover:text-pink-400">微博 {site.weiboName}</a>
          <a href={site.xiaohongshu} target="_blank" rel="noopener" class="block text-sm text-gray-400 hover:text-pink-400">小红书</a>
          <a href={site.douyin} target="_blank" rel="noopener" class="block text-sm text-gray-400 hover:text-pink-400">抖音</a>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-gray-800 text-center text-xs text-gray-600">
      &copy; 2026 {site.name} 应援站. gleams.vip
    </div>
  </div>
</footer>
