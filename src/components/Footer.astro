---
import site from '../data/site.json';
---

<footer class="relative mt-32 pb-12">
  <!-- Gradient line -->
  <div class="h-px bg-gradient-to-r from-transparent via-gleams-500/30 to-transparent mb-12"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <span class="text-2xl">⭐</span>
          <span class="text-xl font-display font-bold gradient-text">{site.name}</span>
        </div>
        <p class="text-sm text-white/40 leading-relaxed">
          {site.descriptionCN}
        </p>
        <div class="flex items-center gap-3 pt-2">
          <a href={site.social.twitter} class="text-white/30 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={site.social.instagram} class="text-white/30 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href={site.social.youtube} class="text-white/30 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href={site.social.bilibili} class="text-white/30 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 01-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 01.16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c0-.373.129-.689.386-.947.258-.257.574-.386.947-.386zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="grid grid-cols-2 gap-6">
        <div class="space-y-3">
          <h4 class="text-sm font-medium text-white/60 tracking-wider uppercase">导航</h4>
          <div class="space-y-2">
            {['首页', '成员介绍', '公演日程', '新闻动态'].map((label, i) => {
              const hrefs = ['/', '/members', '/schedule', '/news'];
              return (
                <a href={hrefs[i]} class="block text-sm text-white/40 hover:text-gleams-400 transition-colors">{label}</a>
              );
            })}
          </div>
        </div>
        <div class="space-y-3">
          <h4 class="text-sm font-medium text-white/60 tracking-wider uppercase">更多</h4>
          <div class="space-y-2">
            <a href="/gallery" class="block text-sm text-white/40 hover:text-gleams-400 transition-colors">照片画廊</a>
            <a href="/about" class="block text-sm text-white/40 hover:text-gleams-400 transition-colors">关于我们</a>
            <a href="https://twitter.com/gleams_official" class="block text-sm text-white/40 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener">X (Twitter)</a>
            <a href="https://weibo.com/gleams_official" class="block text-sm text-white/40 hover:text-gleams-400 transition-colors" target="_blank" rel="noopener">微博</a>
          </div>
        </div>
      </div>

      <!-- Subscribe -->
      <div class="space-y-4">
        <h4 class="text-sm font-medium text-white/60 tracking-wider uppercase">订阅更新</h4>
        <p class="text-sm text-white/40 leading-relaxed">
          关注我们的 SNS 获取 Gleams 最新动态和公演信息！
        </p>
        <a href="/news" class="btn-outline text-xs !px-4 !py-2 inline-flex">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          查看全部新闻
        </a>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-6 border-t border-white/[0.04] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/20">
        &copy; 2026 {site.name}. Made with 💖 by fans.
      </p>
      <p class="text-xs text-white/20">
        gleams.vip
      </p>
    </div>
  </div>
</footer>
