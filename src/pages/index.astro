---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroTitle from '../components/HeroTitle.astro';
import site from '../data/site.json';
import members from '../data/members.json';
import schedule from '../data/schedule.json';

const activeMembers = members.members.filter(m => m.status !== 'graduated');
const pastEvents = schedule.events.filter((e: any) => e.status === 'past').reverse().slice(0, 4);

const newsFiles = Object.values(import.meta.glob('../content/news/*.md', { eager: true }));
const newsSlugMap = new Map(newsFiles.map((n: any) => {
  const slug = n.file.split('/').pop()?.replace('.md', '');
  const d = n.frontmatter.date instanceof Date ? n.frontmatter.date : new Date(n.frontmatter.date);
  const dateStr = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  return [dateStr, slug];
}));

const eventImages: Record<string, string> = {
  'live-2026-01-25': '/images/events/live-2026-01-25.webp',
  'live-2026-01-31': '/images/events/live-2026-01-31.webp',
  'live-2026-02-15': '/images/events/live-2026-02-15.webp',
  'live-2026-02-23': '/images/events/live-2026-02-23.webp',
  'live-2026-03-14': '/images/events/live-2026-03-14.webp',
  'live-2026-03-28': '/images/events/live-2026-03-28.webp',
  'live-2026-04-26': '/images/events/live-2026-04-26.webp',
  'live-2026-05-16': '/images/events/live-2026-05-16.webp',
  'live-2026-07-04': '/images/events/live-2026-07-04.webp',
};
---

<BaseLayout>
  <section class="relative overflow-hidden">
    <img src="/hero-bg.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-[0.25] dark:opacity-[0.12]" fetchpriority="high" decoding="async" />
    <div class="relative max-w-7xl mx-auto px-4 py-16 sm:py-20 md:py-28 text-center">
      <img src="/logo.png" alt={site.name} class="w-24 h-24 sm:w-32 sm:h-32 mx-auto rounded-full shadow-lg mb-6 relative z-10" />
      <HeroTitle name={site.name} subtitle={site.subtitle} />
      <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 max-w-sm sm:max-w-sm mx-auto mb-6 sm:mb-8 px-2">{site.weiboDesc}</p>
      <div class="flex flex-wrap justify-center gap-2 sm:gap-3">
        <a href="/members" class="btn-pink text-xs sm:text-sm !px-4 sm:!px-6 !py-2 sm:!py-2.5">成员介绍</a>
        <a href="/schedule" class="btn-outline text-xs sm:text-sm !px-4 sm:!px-6 !py-2 sm:!py-2.5">公演日程</a>
        <a href={site.weibo} target="_blank" rel="noopener" class="btn-outline text-xs sm:text-sm !px-4 sm:!px-6 !py-2 sm:!py-2.5">微博</a>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-16 md:py-20" data-reveal>
    <div class="text-center mb-10">
      <p class="section-title-en">✦</p>
      <h2 class="section-title">成员</h2>
    </div>
    <div class="grid grid-cols-3 gap-4 sm:gap-6">
      {activeMembers.map(m => (
        <a href={`/members/${m.id}`} class="group block text-center">
          <div class="aspect-[4/5] rounded-3xl overflow-hidden mb-3 glass shadow-md group-hover:shadow-lg transition-shadow">
            <img src={m.image} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <span class="text-xl">{m.emoji}</span>
          <h3 class="text-base font-extrabold text-gray-900 dark:text-gray-100">{m.name}</h3>
          <p class="text-xs text-gray-400 dark:text-gray-500">{m.nameJP}</p>
          <div class="flex items-center justify-center gap-1.5 mt-1">
            <span class="inline-block w-2.5 h-2.5 rounded-full cursor-pointer hover:scale-150 transition-transform" style={`background:${m.color}`} data-member-color={m.id} title={`切换${m.name}主题色`}></span>
            <span class="text-xs text-gray-500 dark:text-gray-400">{m.birthday} · {m.constellation}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="py-16 md:py-20 border-t glass-divider" data-reveal>
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-10">
        <p class="section-title-en">✦</p>
        <h2 class="section-title">过往行程</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
        {pastEvents.map((evt: any) => {
          const d = new Date(evt.date);
          const img = eventImages[evt.id] || '/images/events/live-2026-01-31.webp';
          return (
            <a href={`/news/${newsSlugMap.get(evt.date) || evt.date}`} class="card group">
              <div class="aspect-[16/9] overflow-hidden bg-gray-100 dark:bg-gray-800">
                <img src={img} alt={evt.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-4">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs font-bold text-pink-500">{d.getMonth()+1}/{d.getDate()}</span>
                  <span class="text-xs text-gray-400 dark:text-gray-500">{d.getFullYear()}</span>
                </div>
                <h3 class="text-sm font-bold text-gray-900 dark:text-gray-100 line-clamp-2">{evt.title}</h3>
                <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">{evt.venue}</p>
              </div>
            </a>
          );
        })}
      </div>
      <div class="text-center mt-8">
        <a href="/schedule" class="btn-outline text-xs sm:text-sm">查看完整日程 →</a>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-16 text-center">
    <p class="section-title-en">✦</p>
    <h2 class="section-title mb-8">关注 Gleams</h2>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={site.weibo} target="_blank" rel="noopener" class="btn-outline text-sm !px-5 !py-3">微博</a>
      <a href={site.xiaohongshu} target="_blank" rel="noopener" class="btn-outline text-sm !px-5 !py-3">小红书</a>
      <a href={site.douyin} target="_blank" rel="noopener" class="btn-outline text-sm !px-5 !py-3">抖音</a>
    </div>
  </section>
</BaseLayout>
