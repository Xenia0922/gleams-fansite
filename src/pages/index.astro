---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroTitle from '../components/HeroTitle.astro';
import site from '../data/site.json';
import HomeMembers from '../components/HomeMembers';
import HomeEvents from '../components/HomeEvents';
import { SiteSocial, LiveLink, SiteMeta } from '../components/SiteBits';
import UpcomingCountdown from '../components/UpcomingCountdown';
---

<BaseLayout>
  <section class="relative overflow-hidden">
    <img src="/hero-bg.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-[0.22] dark:opacity-[0.12]" fetchpriority="high" decoding="async" />
    <div class="absolute left-1/2 -translate-x-1/2 top-6 sm:top-10 w-44 h-44 sm:w-56 sm:h-56 rounded-full blur-3xl pointer-events-none" style="background: color-mix(in srgb, var(--accent) 38%, transparent); opacity: 0.55;"></div>
    <div class="relative max-w-7xl mx-auto px-4 py-16 sm:py-20 md:py-28 text-center">
      <img src="/logo.png" alt={site.name} class="rise relative z-10 mx-auto w-24 h-24 sm:w-32 sm:h-32 rounded-full shadow-xl mb-6" style="animation-delay:.05s" />
      <HeroTitle name={site.name} subtitle={site.subtitle} />
      <p class="rise text-xs sm:text-sm text-[var(--text-soft)] dark:text-gray-400 max-w-sm mx-auto mb-7 sm:mb-9 px-2 leading-relaxed" style="animation-delay:.45s">
        <SiteMeta client:load field="weibo_desc" initial={site.weiboDesc} />
      </p>
      <div class="rise flex flex-wrap justify-center gap-2.5 sm:gap-3" style="animation-delay:.55s">
        <a href="/members" class="btn-pink text-xs sm:text-sm !px-5 sm:!px-7 !py-2.5 sm:!py-3">成员介绍</a>
        <a href="/schedule" class="btn-outline text-xs sm:text-sm !px-5 sm:!px-7 !py-2.5 sm:!py-3">公演日程</a>
        <LiveLink client:load field="weibo" label="微博" initial={site.weibo} className="btn-outline text-xs sm:text-sm !px-5 sm:!px-7 !py-2.5 sm:!py-3" />
      </div>
      <div class="mt-6" style="min-height: 0;">
        <UpcomingCountdown client:load />
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-16 md:py-20">
    <div class="text-center mb-10" data-reveal>
      <p class="section-title-en">✦</p>
      <h2 class="section-title">成员</h2>
    </div>
    <HomeMembers client:load initial={[]} />
  </section>

  <section class="py-16 md:py-20 border-t glass-divider">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-10" data-reveal>
        <p class="section-title-en">✦</p>
        <h2 class="section-title">过往行程</h2>
      </div>
      <HomeEvents client:load initial={[]} />
      <div class="text-center mt-8">
        <a href="/schedule" class="btn-outline text-xs sm:text-sm">查看完整日程 →</a>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-16 text-center" data-reveal>
    <p class="section-title-en">✦</p>
    <h2 class="section-title mb-8">关注 Gleams</h2>
    <SiteSocial client:load variant="buttons" initial={{ weibo: site.weibo, xiaohongshu: site.xiaohongshu, douyin: site.douyin }} />
  </section>
</BaseLayout>
