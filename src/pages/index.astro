---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
import members from '../data/members.json';
import schedule from '../data/schedule.json';

const pastEvents = schedule.events.filter((e: any) => e.status === 'past').reverse().slice(0, 4);
const upcomingEvents = schedule.events.filter((e: any) => e.status === 'upcoming');

const eventImages: Record<string, string> = {
  'live-2026-01-25': '/images/events/live-2026-01-25.jpg',
  'live-2026-01-31': '/images/events/live-2026-01-31.jpg',
  'live-2026-02-15': '/images/events/live-2026-02-15.jpg',
  'live-2026-02-23': '/images/events/live-2026-02-23.jpg',
  'live-2026-03-14': '/images/events/live-2026-03-14.jpg',
  'live-2026-03-28': '/images/events/live-2026-03-28.jpg',
  'live-2026-04-26': '/images/events/live-2026-04-26.jpg',
  'live-2026-05-16': '/images/events/live-2026-05-16.jpg',
  'live-2026-07-04': '/images/events/live-2026-07-04.jpg',
};
---

<BaseLayout>
  <!-- Hero — 三端分离字号 -->
  <section class="bg-gradient-to-br from-pink-50 via-white to-purple-50">
    <div class="max-w-4xl mx-auto px-4 py-12 sm:py-16 md:py-24 text-center">
      <p class="text-[10px] sm:text-xs tracking-[0.3em] text-gray-400 uppercase mb-3 sm:mb-4">{site.subtitle}</p>
      <h1 class="text-3xl sm:text-5xl md:text-7xl font-extrabold tracking-tight text-gray-900 mb-3 sm:mb-4">
        {site.name}
      </h1>
      <p class="text-xs sm:text-sm text-gray-500 max-w-sm sm:max-w-md mx-auto mb-6 sm:mb-8 px-2">{site.weiboDesc}</p>
      <div class="flex flex-wrap justify-center gap-2 sm:gap-3">
        <a href="/members" class="btn-pink text-xs sm:text-sm !px-4 sm:!px-6 !py-2 sm:!py-2.5">成员介绍</a>
        <a href="/schedule" class="btn-outline text-xs sm:text-sm !px-4 sm:!px-6 !py-2 sm:!py-2.5">公演日程</a>
        <a href={site.weibo} target="_blank" rel="noopener" class="btn-outline text-xs sm:text-sm !px-4 sm:!px-6 !py-2 sm:!py-2.5">{site.weiboName}</a>
      </div>
    </div>
  </section>

  <!-- Members — 1col手机 / 3col桌面 -->
  <section class="max-w-4xl mx-auto px-4 py-12 sm:py-16 md:py-20">
    <div class="text-center mb-8 sm:mb-12">
      <p class="section-title-en">Member</p>
      <h2 class="section-title">成员</h2>
    </div>
    <div class="space-y-12 md:space-y-16 max-w-md mx-auto">
      {members.members.map(m => (
        <a href={`/members/${m.id}`} class="group block">
          <div class="aspect-[3/4] overflow-hidden bg-gray-100 rounded-2xl mb-4 shadow-md group-hover:shadow-xl transition-shadow">
            <img src={m.image} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="text-center px-1">
            <div class="flex items-center justify-center gap-2 mb-1">
              <span class="text-2xl">{m.emoji}</span>
              <h3 class="text-xl font-extrabold text-gray-900">{m.name}</h3>
            </div>
            <p class="text-sm text-gray-400 mb-1">{m.nameJP}</p>
            <div class="flex items-center justify-center gap-2 mb-3">
              <span class="inline-block w-3 h-3 rounded-full" style={`background:${m.color}`}></span>
              <span class="text-xs text-gray-500">{m.birthday} · {m.constellation}</span>
            </div>
            <span class="inline-block text-xs text-pink-500 font-medium hover:text-pink-600">
              {m.weiboName}
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Past Events — 1col手机 / 2col桌面 -->
  <section class="bg-gray-50 py-12 sm:py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-8 sm:mb-12">
        <p class="section-title-en">Past Events</p>
        <h2 class="section-title">过往行程</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
        {pastEvents.map((evt: any) => {
          const d = new Date(evt.date);
          const img = eventImages[evt.id] || '/images/events/live-2026-01-31.jpg';
          return (
            <div class="card overflow-hidden">
              <div class="aspect-[16/9] overflow-hidden bg-gray-100">
                <img src={img} alt={evt.title} class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="p-3 sm:p-4">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs font-bold text-pink-500">{d.getMonth()+1}/{d.getDate()}</span>
                  <span class="text-[10px] sm:text-xs text-gray-400">{d.getFullYear()}</span>
                </div>
                <h3 class="text-sm font-bold text-gray-900 line-clamp-2">{evt.title}</h3>
                <p class="text-[10px] sm:text-xs text-gray-400 mt-1">{evt.venue}</p>
              </div>
            </div>
          );
        })}
      </div>
      <div class="text-center mt-6 sm:mt-8">
        <a href="/schedule" class="btn-outline text-xs sm:text-sm">查看完整日程 →</a>
      </div>
    </div>
  </section>

  <!-- Social -->
  <section class="max-w-2xl mx-auto px-4 py-12 sm:py-16 text-center">
    <p class="section-title-en">Follow Us</p>
    <h2 class="section-title mb-6 sm:mb-8">关注 Gleams</h2>
    <div class="flex flex-wrap justify-center gap-2 sm:gap-4">
      <a href={site.weibo} target="_blank" rel="noopener" class="btn-outline text-xs sm:text-sm !px-4 sm:!px-5 !py-2 sm:!py-3">微博 {site.weiboName}</a>
      <a href={site.xiaohongshu} target="_blank" rel="noopener" class="btn-outline text-xs sm:text-sm !px-4 sm:!px-5 !py-2 sm:!py-3">小红书</a>
      <a href={site.douyin} target="_blank" rel="noopener" class="btn-outline text-xs sm:text-sm !px-4 sm:!px-5 !py-2 sm:!py-3">抖音</a>
    </div>
  </section>
</BaseLayout>
