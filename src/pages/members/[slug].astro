---
import BaseLayout from '../../layouts/BaseLayout.astro';
import membersData from '../../data/members.json';

export function getStaticPaths() {
  return membersData.members.map(m => ({ params: { slug: m.id }, props: { member: m } }));
}

const { member } = Astro.props;
const [month, day] = (member.birthday || "--").split('-');
---

<BaseLayout title={member.name}>
  <section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <a href="/members" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-gray-600 dark:text-gray-400 mb-6">← 返回</a>

    <div class="flex flex-col md:flex-row gap-6 md:gap-10">
      <div class="md:w-80 flex-shrink-0 mx-auto md:mx-0 max-w-64 md:max-w-none">
        <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-gray-100 dark:bg-gray-800 shadow-md">
          <img src={member.image} alt={member.name} class="w-full h-full object-cover" />
        </div>
      </div>

      <div class="flex-1 space-y-5">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-2xl">{member.emoji}</span>
          <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-gray-100">{member.name}</h1>
          <span class="text-sm text-gray-400">{member.nameJP}</span>
        </div>

        <div class="flex flex-wrap gap-2 text-sm">
          <span class="bg-gray-100 text-gray-600 px-3 py-1 rounded-full">{month}月{day}日</span>
          <span class="bg-gray-100 text-gray-600 px-3 py-1 rounded-full">{member.constellation}</span>
          <span class="inline-flex items-center gap-1.5 bg-gray-100 text-gray-600 px-3 py-1 rounded-full">
            <span class="w-2.5 h-2.5 rounded-full" style={`background:${member.color}`}></span>成员色
          </span>
        </div>

        <div class="bg-gray-50 dark:bg-gray-900 rounded-2xl p-4">
          <p class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed">{member.intro}</p>
        </div>

        {member.weibo && (
          <div>
            <a href={member.weibo} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm text-pink-500 hover:text-pink-600 font-medium">
              {member.weiboName}
            </a>
            <p class="text-xs text-gray-400 mt-1">{member.weiboDesc}</p>
          </div>
        )}

        {member.gallery.length > 0 && (
          <div>
            <h3 class="text-sm font-bold text-gray-900 dark:text-gray-100 mb-3">更多照片</h3>
            <div class="grid grid-cols-3 gap-2">
              {member.gallery.map((img: string, i: number) => (
                <a href={img} target="_blank" rel="noopener" class="aspect-[4/5] rounded-2xl overflow-hidden bg-gray-100 block">
                  <img src={img} alt="" class="w-full h-full object-cover hover:scale-105 transition-transform" loading="lazy" />
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
