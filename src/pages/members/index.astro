---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MemberCard from '../../components/MemberCard.astro';
import membersData from '../../data/members.json';

const { generations, members } = membersData;
---

<BaseLayout title="成员介绍">
  <section class="pt-32 pb-24 px-4">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-16">
        <p class="section-subtitle mb-3 animate-fade-in">♡ Members ♡</p>
        <h2 class="section-title animate-slide-up">成员介绍</h2>
        <p class="text-white/30 mt-4 max-w-2xl mx-auto animate-slide-up-delayed">
          輝く6つの星 —— 闪耀的六颗星，各自绽放独特的光芒
        </p>
      </div>

      <!-- Filter Tabs -->
      <div class="flex justify-center gap-2 mb-12 flex-wrap" id="filter-tabs">
        {generations.filter(g => g !== 'ALL').map((gen, i) => (
          <button
            class={`filter-btn px-5 py-2 rounded-xl text-sm font-medium transition-all duration-300
              ${i === 0 ? 'bg-gleams-500/10 text-gleams-400 border border-gleams-500/20' : 'text-white/40 hover:text-white/70 border border-transparent hover:border-white/10'}`}
            data-filter={gen}
          >
            {gen}
          </button>
        ))}
      </div>

      <!-- Member Grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 md:gap-6" id="members-grid">
        {members.map(member => (
          <div class="member-item" data-generation={member.generation}>
            <MemberCard member={member} />
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-16 text-white/30">
        <span class="text-4xl mb-4 block">💫</span>
        <p>该分类下暂无成员</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const memberItems = document.querySelectorAll('.member-item');
  const emptyState = document.getElementById('empty-state');
  const grid = document.getElementById('members-grid');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      // Update active button style
      filterBtns.forEach(b => {
        b.classList.remove('bg-gleams-500/10', 'text-gleams-400', 'border-gleams-500/20');
        b.classList.add('text-white/40', 'border-transparent');
      });
      btn.classList.add('bg-gleams-500/10', 'text-gleams-400', 'border-gleams-500/20');
      btn.classList.remove('text-white/40', 'border-transparent');

      let visibleCount = 0;
      memberItems.forEach(item => {
        const gen = item.getAttribute('data-generation');
        if (gen === filter) {
          (item as HTMLElement).style.display = '';
          visibleCount++;
          item.classList.add('animate-fade-in');
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });

      if (emptyState && grid) {
        emptyState.classList.toggle('hidden', visibleCount > 0);
        (grid as HTMLElement).style.display = visibleCount > 0 ? '' : 'none';
      }
    });
  });
</script>
