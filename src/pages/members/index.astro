---
import BaseLayout from '../../layouts/BaseLayout.astro';
import membersData from '../../data/members.json';
---

<BaseLayout title="MEMBER | 成员">
  <section class="py-12 md:py-20 px-4 max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <p class="section-title-en">Member</p>
      <h1 class="section-title">成员</h1>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 md:gap-8 max-w-3xl mx-auto">
      {membersData.members.map(m => (
        <a href={`/members/${m.id}`} class="card group text-center">
          <div class="aspect-square overflow-hidden bg-gray-100">
            <img src={m.image} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-4">
            <span class="text-2xl block mb-1">{m.emoji}</span>
            <h3 class="text-lg font-extrabold text-gray-900">{m.name}</h3>
            <p class="text-xs text-gray-400">{m.nameJP}</p>
            <div class="flex items-center justify-center gap-1 mt-2 mb-2">
              <span class="inline-block w-2.5 h-2.5 rounded-full" style={`background:${m.color}`}></span>
              <span class="text-xs text-gray-500">{m.birthday}</span>
            </div>
            <a href={m.weibo} target="_blank" rel="noopener" class="text-xs text-pink-500 hover:text-pink-600" onclick="event.stopPropagation()">
              {m.weiboName}
            </a>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
