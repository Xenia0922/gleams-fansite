---
import BaseLayout from '../../layouts/BaseLayout.astro';
import membersData from '../../data/members.json';
---

<BaseLayout title="MEMBER | 成员">
  <section class="py-16 md:py-20 px-4 max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <p class="section-title-en">Member</p>
      <h1 class="section-title">成员介绍</h1>
      <p class="text-gray-400 mt-3">三位来自不同城堡的公主</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {membersData.members.map(m => (
        <a href={`/members/${m.id}`} class="card group">
          <div class="aspect-[3/4] overflow-hidden bg-gray-100">
            <img src={m.image} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl">{m.emoji}</span>
              <div>
                <h3 class="text-lg font-bold text-gray-900">{m.name}</h3>
                <p class="text-xs text-gray-400">{m.nameJP}</p>
              </div>
            </div>
            <div class="flex items-center gap-2 mb-3">
              <span class="inline-block w-3 h-3 rounded-full" style={`background:${m.color}`}></span>
              <span class="text-xs text-gray-500">{m.birthday} · {m.constellation}</span>
            </div>
            <p class="text-sm text-gray-500 line-clamp-2 mb-3">{m.bio}</p>
            <a href={m.weibo} target="_blank" rel="noopener" class="text-xs text-pink-500 hover:text-pink-600 font-medium inline-flex items-center gap-1" onclick="event.stopPropagation()">
              {m.weiboName} →
            </a>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
