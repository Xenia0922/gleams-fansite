---
import BaseLayout from '../../layouts/BaseLayout.astro';
import membersData from '../../data/members.json';

const active = membersData.members.filter(m => m.status === 'active');
const graduated = membersData.members.filter(m => m.status === 'graduated');
---

<BaseLayout title="成员">
  <section class="max-w-4xl mx-auto px-4 py-16 md:py-20">
    <div class="text-center mb-10">
      <p class="section-title-en">✦</p>
      <h1 class="section-title">成员</h1>
    </div>

    <div class="grid grid-cols-3 gap-4 sm:gap-6 mb-16">
      {active.map(m => (
        <a href={`/members/${m.id}`} class="group block text-center">
          <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-gray-100 mb-3 shadow-sm group-hover:shadow-md transition-shadow">
            <img src={m.image} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <span class="text-xl">{m.emoji}</span>
          <h3 class="text-base font-extrabold text-gray-900">{m.name}</h3>
          <p class="text-xs text-gray-400">{m.nameJP}</p>
          <div class="flex items-center justify-center gap-1.5 mt-1">
            <span class="inline-block w-2.5 h-2.5 rounded-full" style={`background:${m.color}`}></span>
            <span class="text-xs text-gray-500">{m.birthday} · {m.constellation}</span>
          </div>
        </a>
      ))}
    </div>

    {graduated.length > 0 && (
      <div class="border-t border-gray-100 pt-10">
        <h2 class="text-xs font-bold text-gray-400 tracking-widest text-center mb-6">毕业成员</h2>
        <div class="grid grid-cols-3 gap-4 sm:gap-6 opacity-60">
          {graduated.map(m => (
            <div class="text-center">
              <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-gray-100 mb-3 grayscale">
                <img src={m.image} alt={m.name} class="w-full h-full object-cover" loading="lazy" />
              </div>
              <span class="text-xl">{m.emoji}</span>
              <h3 class="text-base font-extrabold text-gray-500">{m.name}</h3>
              <p class="text-xs text-gray-400">{m.intro}</p>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
