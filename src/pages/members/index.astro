---
import BaseLayout from '../../layouts/BaseLayout.astro';
import membersData from '../../data/members.json';
---

<BaseLayout title="MEMBER | 成员">
  <section class="max-w-4xl mx-auto px-4 py-12 sm:py-16 md:py-20">
    <div class="text-center mb-8 sm:mb-12">
      <p class="section-title-en">Member</p>
      <h1 class="section-title">成员</h1>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
      {membersData.members.map(m => (
        <a href={`/members/${m.id}`} class="card group text-center">
          <div class="aspect-[3/4] overflow-hidden bg-gray-100">
            <img src={m.image} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-2 sm:p-4">
            <span class="text-lg sm:text-2xl block mb-0.5 sm:mb-1">{m.emoji}</span>
            <h3 class="text-sm sm:text-lg font-extrabold text-gray-900">{m.name}</h3>
            <p class="text-[10px] sm:text-xs text-gray-400">{m.nameJP}</p>
            <div class="flex items-center justify-center gap-1 mt-1 sm:mt-2 mb-1 sm:mb-2">
              <span class="inline-block w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full" style={`background:${m.color}`}></span>
              <span class="text-[10px] sm:text-xs text-gray-500">{m.birthday}</span>
            </div>
            <a href={m.weibo} target="_blank" rel="noopener" class="text-[10px] sm:text-xs text-pink-500 hover:text-pink-600" onclick="event.stopPropagation()">
              {m.weiboName}
            </a>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
