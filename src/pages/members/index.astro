---
import BaseLayout from '../../layouts/BaseLayout.astro';
import membersData from '../../data/members.json';

const active = membersData.members.filter(m => m.status === 'active');
const graduated = membersData.members.filter(m => m.status === 'graduated');
---

<BaseLayout title="成员">
  <section class="max-w-4xl mx-auto px-4 py-16 md:py-20">
    <div class="text-center mb-10">
      <p class="section-title-en">✦</p>
      <h1 class="section-title">成员</h1>
    </div>

    <!-- 正在活动 -->
    <p class="text-xs font-bold text-pink-500 tracking-widest text-center mb-5">正在活动</p>
    <div class="grid grid-cols-3 gap-4 sm:gap-6 mb-16">
      {active.map(m => (
        <a href={`/members/${m.id}`} class="group block text-center">
          <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-gray-100 dark:bg-gray-800 mb-3 shadow-sm group-hover:shadow-md transition-shadow">
            <img src={m.image} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <span class="text-xl">{m.emoji}</span>
          <h3 class="text-base font-extrabold text-gray-900 dark:text-gray-100">{m.name}</h3>
          <p class="text-xs text-gray-400 dark:text-gray-500">{m.nameJP}</p>
          <div class="flex items-center justify-center gap-1.5 mt-1">
            <span class="inline-block w-2.5 h-2.5 rounded-full" style={`background:${m.color}`}></span>
            <span class="text-xs text-gray-500 dark:text-gray-400">{m.birthday} · {m.constellation}</span>
          </div>
        </a>
      ))}
    </div>

    <!-- 已毕业 -->
    {graduated.length > 0 && (
      <div class="border-t border-gray-100 dark:border-gray-800 pt-10">
        <p class="text-xs font-bold text-gray-400 tracking-widest text-center mb-5">已毕业</p>
        <div class="grid grid-cols-3 gap-4 sm:gap-6">
          {graduated.map(m => (
            <a href={`/members/${m.id}`} class="text-center block group">
              <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-gray-100 dark:bg-gray-800 mb-3 shadow-sm flex items-center justify-center">
                {m.image ? <img src={m.image} alt={m.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" /> : <span class="text-4xl">{m.emoji}</span>}
              </div>
              <span class="text-xl">{m.emoji}</span>
              <h3 class="text-base font-extrabold text-gray-900 dark:text-gray-100">{m.name}</h3>
              <p class="text-xs text-gray-400 dark:text-gray-500">{m.nameJP}</p>
              <div class="flex items-center justify-center gap-1.5 mt-1">
                <span class="inline-block w-2.5 h-2.5 rounded-full" style={`background:${m.color}`}></span>
                <span class="text-xs text-gray-500 dark:text-gray-400">{m.birthday} · {m.constellation}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
