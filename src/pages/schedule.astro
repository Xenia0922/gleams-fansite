---
import BaseLayout from '../layouts/BaseLayout.astro';
import scheduleData from '../data/schedule.json';
import membersData from '../data/members.json';
import { eventReportEntries } from '../utils/eventReports';
import ScheduleList from '../components/ScheduleList';

const reportMap: Record<string, string> = {};
for (const { slug, report } of eventReportEntries) {
  const d = report.frontmatter.date;
  const dt = d instanceof Date ? d : new Date(d);
  const key = `${dt.getFullYear()}-${String(dt.getMonth() + 1).padStart(2, '0')}-${String(dt.getDate()).padStart(2, '0')}`;
  reportMap[key] = slug;
}
---

<BaseLayout title="日程">
  <section class="max-w-4xl mx-auto px-4 py-12 sm:py-16 md:py-20">
    <div class="text-center mb-10">
      <p class="section-title-en">✦</p>
      <h1 class="section-title">日程</h1>
    </div>

    <ScheduleList client:load initial={scheduleData.events} initialMembers={membersData.members} reportMap={reportMap} />
  </section>
</BaseLayout>
