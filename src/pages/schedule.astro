---
import BaseLayout from '../layouts/BaseLayout.astro';
import scheduleData from '../data/schedule.json';
import membersData from '../data/members.json';

const memberMap = new Map(membersData.members.map(m => [m.id, m]));
const upcoming = scheduleData.events.filter((e: any) => e.status === 'upcoming');
const past = scheduleData.events.filter((e: any) => e.status === 'past');
---

<BaseLayout title="SCHEDULE | 公演日程">
  <section class="py-16 md:py-20 px-4 max-w-3xl mx-auto">
    <div class="text-center mb-12">
      <p class="section-title-en">Schedule</p>
      <h1 class="section-title">公演日程</h1>
    </div>

    <!-- Upcoming -->
    {upcoming.length > 0 && (
      <div class="mb-16">
        <h2 class="text-sm font-bold text-pink-500 tracking-widest mb-6">◆ UPCOMING</h2>
        {upcoming.map((evt: any) => {
          const d = new Date(evt.date);
          return (
            <div class="card p-5 mb-4 flex flex-col sm:flex-row sm:items-center gap-4">
              <div class="w-16 h-16 rounded-xl bg-pink-500 text-white flex flex-col items-center justify-center flex-shrink-0">
                <span class="text-xl font-extrabold leading-none">{d.getDate()}</span>
                <span class="text-[10px]">{d.getMonth()+1}/{d.getFullYear()}</span>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-bold text-gray-900">{evt.titleCN || evt.title}</h3>
                <p class="text-sm text-gray-500">{evt.venueCN || evt.venue} · {evt.time}开演</p>
                <div class="flex flex-wrap gap-1 mt-2">
                  {evt.performers.map((pid: string) => {
                    const m = memberMap.get(pid);
                    return m ? <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">{m.emoji} {m.name}</span> : null;
                  })}
                </div>
              </div>
              {evt.ticketUrl ? <a href={evt.ticketUrl} target="_blank" rel="noopener" class="btn-pink text-sm flex-shrink-0">购票</a> : <span class="text-xs text-gray-400 flex-shrink-0">票务未定</span>}
            </div>
          );
        })}
      </div>
    )}

    <!-- Past -->
    {past.length > 0 && (
      <div>
        <h2 class="text-sm font-bold text-gray-400 tracking-widest mb-6">◆ PAST</h2>
        {past.map((evt: any) => {
          const d = new Date(evt.date);
          return (
            <div class="card p-4 mb-3 flex items-center gap-4 opacity-70 hover:opacity-100 transition-opacity">
              <div class="text-center min-w-[50px]">
                <span class="text-gray-400 font-bold">{d.getMonth()+1}/{d.getDate()}</span>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-medium text-gray-700">{evt.titleCN || evt.title}</h3>
                <p class="text-xs text-gray-400">{evt.venueCN || evt.venue}</p>
              </div>
            </div>
          );
        })}
      </div>
    )}

    {upcoming.length === 0 && past.length === 0 && (
      <p class="text-center text-gray-400 py-16">暂无日程，关注微博获取最新消息</p>
    )}
  </section>
</BaseLayout>
