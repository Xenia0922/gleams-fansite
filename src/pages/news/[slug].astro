---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StaticImageLightbox from '../../components/StaticImageLightbox';
import scheduleData from '../../data/schedule.json';
import { eventReportEntries } from '../../utils/eventReports';

export async function getStaticPaths() {
  return eventReportEntries.map(({ slug, report }) => ({
    params: { slug },
    props: { report },
  }));
}

const { report } = Astro.props;
const { frontmatter } = report;
const { Content } = report;

const d = frontmatter.date instanceof Date ? frontmatter.date : new Date(frontmatter.date);
const dateStr = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
const evt = scheduleData.events.find((e: any) => e.date === dateStr);
---

<BaseLayout title={frontmatter.title}>
  <article class="max-w-3xl mx-auto px-4 py-12 md:py-16">
    <a href="/schedule" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-gray-600 dark:text-gray-400 mb-6">← 返回日程</a>

    <!-- 活动信息卡片 -->
    {evt && (
      <div class="flex flex-wrap gap-2 mb-6 text-sm">
        <span class="bg-pink-50 dark:bg-gray-800 text-pink-600 px-3 py-1.5 rounded-full font-medium">
          {d.getMonth()+1}月{d.getDate()}日
        </span>
        {evt.time && <span class="bg-gray-100 dark:bg-gray-800 text-gray-600 px-3 py-1.5 rounded-full">{evt.time}</span>}
        <span class="bg-gray-100 text-gray-600 px-3 py-1.5 rounded-full">{evt.venue}</span>
      </div>
    )}

    <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-gray-100 mb-2">{frontmatter.title}</h1>
    {frontmatter.excerpt && <p class="text-gray-500 dark:text-gray-400 mb-8">{frontmatter.excerpt}</p>}

    <!-- 图片 -->
    {frontmatter.image && (
      <StaticImageLightbox
        client:load
        images={[{ src: frontmatter.image, alt: frontmatter.title }]}
        mode="single"
        itemClassName="rounded-2xl overflow-hidden bg-gray-100 mb-8 block w-full"
        imageClassName="w-full object-cover max-h-[500px]"
      />
    )}

    <!-- 内容 -->
    <div class="prose max-w-none prose-gray prose-sm">
      <Content />
    </div>
  </article>

</BaseLayout>
