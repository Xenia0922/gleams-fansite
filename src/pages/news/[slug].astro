---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const postModules = import.meta.glob('../../content/news/*.md', { eager: true });
  return Object.entries(postModules).map(([filepath, post]: [string, any]) => ({
    params: { slug: filepath.split('/').pop()?.replace('.md', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { frontmatter } = post;
const { Content } = post;

const formattedDate = new Date(frontmatter.date).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={frontmatter.titleCN || frontmatter.title} description={frontmatter.excerpt} image={frontmatter.image}>
  <article class="pt-32 pb-24 px-4">
    <div class="max-w-3xl mx-auto">
      <!-- Back link -->
      <a href="/news" class="inline-flex items-center gap-2 text-white/40 hover:text-gleams-400 transition-colors text-sm mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        返回新闻列表
      </a>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex flex-wrap items-center gap-2 mb-4">
          {frontmatter.tags?.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
          <time datetime={frontmatter.date} class="text-xs text-white/30">{formattedDate}</time>
        </div>
        <h1 class="text-3xl md:text-4xl font-display font-bold text-white mb-4">
          {frontmatter.titleCN || frontmatter.title}
        </h1>
        {frontmatter.author && (
          <p class="text-white/40 text-sm">By {frontmatter.author}</p>
        )}
      </header>

      <!-- Featured Image -->
      {frontmatter.image && (
        <div class="mb-10 rounded-2xl overflow-hidden">
          <img
            src={frontmatter.image}
            alt={frontmatter.title}
            class="w-full aspect-[2/1] object-cover"
          />
        </div>
      )}

      <!-- Content -->
      <div class="glass-card p-6 md:p-10 prose-custom">
        <div class="prose prose-invert max-w-none
          prose-headings:text-white
          prose-p:text-white/70 prose-p:leading-relaxed
          prose-a:text-gleams-400 prose-a:no-underline hover:prose-a:text-gleams-300
          prose-strong:text-white/90
          prose-code:text-gleams-400 prose-code:bg-white/5 prose-code:px-1 prose-code:py-0.5 prose-code:rounded
          prose-table:text-white/70 prose-table:border-white/10
          prose-th:text-white/80 prose-th:border-white/10
          prose-td:border-white/5
          prose-li:text-white/60
          prose-hr:border-white/10
          prose-blockquote:text-white/50 prose-blockquote:border-gleams-500/50
          prose-img:rounded-xl">
          <Content />
        </div>
      </div>

      <!-- Share -->
      <div class="mt-10 flex items-center gap-4 justify-end">
        <span class="text-white/30 text-sm">分享：</span>
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(frontmatter.title)}&url=${encodeURIComponent(new URL(Astro.url.pathname, Astro.site).href)}`}
          target="_blank"
          rel="noopener"
          class="text-white/40 hover:text-gleams-400 transition-colors"
          title="X(Twitter)"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .prose-custom {
    /* Tailwind Typography overrides don't always work in Astro, so extra styles */
  }
</style>
