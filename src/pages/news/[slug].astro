---
import BaseLayout from '../../layouts/BaseLayout.astro';
import scheduleData from '../../data/schedule.json';

export async function getStaticPaths() {
  const postModules = import.meta.glob('../../content/news/*.md', { eager: true });
  return Object.entries(postModules).map(([filepath, post]: [string, any]) => ({
    params: { slug: filepath.split('/').pop()?.replace('.md', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { frontmatter } = post;
const { Content } = post;

const d = new Date(frontmatter.date);
const evt = scheduleData.events.find((e: any) => e.date === frontmatter.date);
---

<BaseLayout title={frontmatter.title}>
  <article class="max-w-3xl mx-auto px-4 py-12 md:py-16">
    <a href="/news" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-gray-600 mb-6">← 返回</a>

    <!-- 活动信息卡片 -->
    {evt && (
      <div class="flex flex-wrap gap-2 mb-6 text-sm">
        <span class="bg-pink-50 text-pink-600 px-3 py-1.5 rounded-full font-medium">
          {d.getMonth()+1}月{d.getDate()}日
        </span>
        {evt.time && <span class="bg-gray-100 text-gray-600 px-3 py-1.5 rounded-full">{evt.time}</span>}
        <span class="bg-gray-100 text-gray-600 px-3 py-1.5 rounded-full">{evt.venue}</span>
      </div>
    )}

    <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-gray-100 mb-2">{frontmatter.title}</h1>
    {frontmatter.excerpt && <p class="text-gray-500 dark:text-gray-400 mb-8">{frontmatter.excerpt}</p>}

    <!-- 图片 -->
    {frontmatter.image && (
      <div class="rounded-2xl overflow-hidden bg-gray-100 mb-8 cursor-pointer" onclick="document.getElementById('full-img').src=this.querySelector('img').src;document.getElementById('img-overlay').classList.remove('hidden')">
        <img src={frontmatter.image} alt={frontmatter.title} class="w-full object-cover max-h-[500px]" />
      </div>
    )}

    <!-- 内容 -->
    <div class="prose max-w-none prose-gray prose-sm">
      <Content />
    </div>
  </article>

  <!-- 全屏图片预览 -->
  <div id="img-overlay" class="hidden fixed inset-0 z-[100] bg-black/95 flex items-center justify-center cursor-pointer" onclick="this.classList.add('hidden')">
    <img id="full-img" src="" alt="" class="max-w-[95vw] max-h-[95vh] object-contain" />
  </div>
</BaseLayout>
