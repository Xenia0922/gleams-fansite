---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';

const allNews = Object.values(import.meta.glob('../../content/news/*.md', { eager: true }));
const sortedNews = allNews.sort(
  (a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<BaseLayout title="REPORT | 活动结算">
  <section class="pt-32 pb-24 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <p class="section-subtitle mb-3 animate-fade-in">✧ Report ✧</p>
        <h2 class="section-title animate-slide-up">活动结算</h2>
        <p class="text-white/30 mt-4 animate-slide-up-delayed">
          各場演出セットリストと出演メンバー
        </p>
      </div>

      {sortedNews.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedNews.map(post => (
            <NewsCard
              title={post.frontmatter.titleCN || post.frontmatter.title}
              date={post.frontmatter.date}
              image={post.frontmatter.image}
              excerpt={post.frontmatter.excerpt}
              tags={post.frontmatter.tags}
              slug={post.file.split('/').pop()?.replace('.md', '') || ''}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-white/30 glass-card">
          <span class="text-4xl mb-4 block">📰</span>
          <p>暂无活动结算</p>
        </div>
      )}

      <!-- RSS -->
      <div class="text-center mt-12">
        <a href="/rss.xml" class="btn-outline text-sm">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27zm0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93z"/></svg>
          RSS 订阅
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
