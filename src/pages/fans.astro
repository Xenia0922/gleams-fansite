---
import BaseLayout from '../layouts/BaseLayout.astro';
import FanUpload from '../components/FanUpload';
import MessageBoard from '../components/MessageBoard';
import FanGallery from '../components/FanGallery';
---

<BaseLayout title="骑士团广场">
  <section class="max-w-3xl mx-auto px-4 py-12 md:py-20">
    <div class="text-center mb-10">
      <p class="section-title-en">✦</p>
      <h1 class="section-title">骑士团广场</h1>
      <p class="text-gray-400 mt-2">分享你拍到的 Gleams 瞬间，为公主们应援打 call</p>
    </div>

    <!-- 标签切换 -->
    <div class="flex justify-center gap-3 mb-8" id="fan-tabs">
      <button class="btn-pink text-sm !px-5 !py-2" data-tab="browse">💬 浏览</button>
      <button class="btn-outline text-sm !px-5 !py-2" data-tab="post">✏️ 发布</button>
    </div>

    <!-- 浏览模式（默认） -->
    <div id="tab-browse">
      <div class="mb-12" data-reveal>
        <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4">💬 应援留言板</h2>
        <MessageBoard client:load readonly />
      </div>
      <div data-reveal>
        <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4">📸 骑士返图</h2>
        <FanGallery client:idle />
      </div>
    </div>

    <!-- 发布模式（隐藏） -->
    <div id="tab-post" class="hidden">
      <div class="mb-12" data-reveal>
        <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4">✏️ 发留言</h2>
        <MessageBoard client:idle />
      </div>
      <div data-reveal>
        <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4">📸 分享现场照</h2>
        <FanUpload client:idle />
      </div>
      <p class="text-center mt-6">
        <button id="hint-btn" class="text-[11px] text-gray-400 hover:text-pink-400 dark:text-gray-500 dark:hover:text-pink-400 transition-colors bg-transparent border-none cursor-pointer">
          不知道暗号？点这里试试！
        </button>
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll('#fan-tabs button');
  const browse = document.getElementById('tab-browse');
  const post = document.getElementById('tab-post');

  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;
      tabs.forEach(b => { b.className = 'btn-outline text-sm !px-5 !py-2'; });
      btn.className = 'btn-pink text-sm !px-5 !py-2';

      if (tab === 'browse') {
        browse.classList.remove('hidden');
        post.classList.add('hidden');
      } else {
        browse.classList.add('hidden');
        post.classList.remove('hidden');
      }
    });
  });

  // 暗号提示切换
  const hint = document.getElementById('hint-btn');
  let hintOn = false;
  hint?.addEventListener('click', () => {
    hintOn = !hintOn;
    hint.textContent = hintOn ? 'Gleams应援会QQ群：480408977' : '不知道暗号？点这里试试！';
  });
</script>
