---
import BaseLayout from '../layouts/BaseLayout.astro';
import FanUpload from '../components/FanUpload';
import MessageBoard from '../components/MessageBoard';
---

<BaseLayout title="骑士团广场">
  <section class="max-w-3xl mx-auto px-4 py-12 md:py-20">
    <div class="text-center mb-10">
      <p class="section-title-en">✦</p>
      <h1 class="section-title">骑士团广场</h1>
      <p class="text-gray-400 mt-2">分享你拍到的 Gleams 瞬间，为公主们应援打 call</p>
    </div>

    <!-- 留言板 -->
    <div class="mb-12" data-reveal>
      <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4">💬 应援留言板</h2>
      <MessageBoard client:load />
    </div>

    <!-- 照片上传 -->
    <div class="mb-12" data-reveal>
      <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-4">📸 分享现场照</h2>
      <FanUpload client:load />
    </div>
  </section>
</BaseLayout>
