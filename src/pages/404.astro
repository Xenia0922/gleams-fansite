---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 | 页面未找到">
  <section class="min-h-[60vh] flex items-center justify-center px-4 text-center">
    <div>
      <p class="text-8xl font-extrabold text-pink-200 mb-4">404</p>
      <h1 class="text-xl font-bold text-gray-900 mb-2">页面未找到</h1>
      <p class="text-gray-400 mb-8">公主们不在这里，返回首页吧</p>
      <div class="flex justify-center gap-3">
        <a href="/" class="btn-pink">返回首页</a>
        <a href="/schedule" class="btn-outline">公演日程</a>
      </div>
    </div>
  </section>
</BaseLayout>
