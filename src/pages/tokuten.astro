---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout title="特典 | 特典规则">
  <section class="py-16 md:py-20 px-4 max-w-2xl mx-auto">
    <div class="text-center mb-12">
      <p class="section-title-en">Tokuten</p>
      <h1 class="section-title">特典规则</h1>
      <p class="text-gray-400 mt-3">请各位骑士仔细阅读并遵守以下规则</p>
    </div>

    <div class="card p-8 space-y-6">
      <ol class="space-y-4">
        {site.tokutenRules.map((rule: string, i: number) => (
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-7 h-7 rounded-full bg-pink-100 text-pink-500 text-sm font-bold flex items-center justify-center">{i + 1}</span>
            <span class="text-gray-700 leading-relaxed pt-0.5">{rule}</span>
          </li>
        ))}
      </ol>
    </div>

    <div class="mt-8 text-center">
      <p class="text-sm text-gray-400 mb-4">如有疑问请私信官博</p>
      <a href={site.weibo} target="_blank" rel="noopener" class="btn-pink">联系官博 {site.weiboName}</a>
    </div>
  </section>
</BaseLayout>
